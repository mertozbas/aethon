{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "codex-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Codex Proxy",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "apiKey": "pwd"
      },
      "models": {
        "codex": {
          "name": "Codex (GPT-5.3)",
